{
  "rules": {
    ".read": "auth !== null && auth.token.email_verified === true && root.child('allowlist').child(auth.token.email.toLowerCase().replace('.', ',')).exists()",
    ".write": "auth !== null && auth.token.email_verified === true && root.child('allowlist').child(auth.token.email.toLowerCase().replace('.', ',')).child('role').val() === 'owner'"
  }
}
