rules_version = '2';

// Authenticated-only access. Tighten to a specific admin UID by replacing
// `request.auth != null` with `request.auth.uid == '<ADMIN_UID>'`.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
