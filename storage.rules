rules_version = '2';

// Authenticated + allowlisted users only. Owners may write; viewers read.
service firebase.storage {
  match /b/{bucket}/o {
    function emailKey() {
      return request.auth.token.email.lower();
    }
    function isAllowlisted() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/allowlist/$(emailKey()));
    }
    function isOwner() {
      return isAllowlisted()
        && firestore.get(/databases/(default)/documents/allowlist/$(emailKey())).data.role == 'owner';
    }

    match /{allPaths=**} {
      allow read: if isAllowlisted();
      allow write: if isOwner();
      // Cap uploads at 25MB to mitigate storage-abuse / DoS.
      allow create: if isOwner() && request.resource.size < 25 * 1024 * 1024;
    }
  }
}
