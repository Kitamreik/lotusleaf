rules_version = '2';

// Lock down: only authenticated users may read/write. If a single-admin
// deployment is desired, restrict further by replacing the auth check with
// `request.auth.uid == '<ADMIN_UID>'`.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
