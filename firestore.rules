rules_version = '2';

// Defense-in-depth: only authenticated AND allowlisted users may read.
// Writes additionally require an `owner` role. The `allowlist` collection
// itself is readable by any allowlisted user (so the app can render roles)
// but writable only by owners.
service cloud.firestore {
  match /databases/{database}/documents {
    function emailKey() {
      return request.auth.token.email.lower();
    }
    function isAllowlisted() {
      return request.auth != null
        && exists(/databases/$(database)/documents/allowlist/$(emailKey()));
    }
    function isOwner() {
      return isAllowlisted()
        && get(/databases/$(database)/documents/allowlist/$(emailKey())).data.role == 'owner';
    }

    // Allowlist access is split: each authenticated user may only `get` their
    // own entry (used by checkAllowlist on login). Only owners may `list` the
    // full collection (used by the Settings admin UI) or write to it. This
    // prevents staff-email enumeration by any Firebase-authenticated user.
    // Bootstrap: the first owner must be created out-of-band via the Firebase
    // Console (Firestore → allowlist collection → doc id = lowercase email).
    match /allowlist/{email} {
      allow get: if request.auth != null
        && request.auth.token.email.lower() == email;
      allow list: if isOwner();
      allow write: if isOwner();
    }

    // Portal client records contain magic-link tokens, document data URLs,
    // and signer PII. Restrict to owners only — viewers must NOT see tokens
    // or be able to impersonate clients via /portal?t=<token>.
    match /portal_clients/{clientId} {
      allow read, write: if isOwner();
    }

    match /{document=**} {
      allow read: if isAllowlisted();
      allow write: if isOwner();
    }
  }
}
